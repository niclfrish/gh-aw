{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "manifest-version": {
      "type": "string",
      "enum": ["1"]
    },
    "min-version": {
      "type": "string",
      "description": "Minimum supported gh-aw CLI version. Requires the exact vMAJOR.minor.patch form.",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "emoji": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
